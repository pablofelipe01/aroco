# CacaoQ — Variables de entorno
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Turso (SQLite remoto) — dejar vacío para usar SQLite local
TURSO_DATABASE_URL=libsql://tu-db-tu-usuario.turso.io
TURSO_AUTH_TOKEN=tu-token-aqui

# MCP servers (vía Cloudflare Tunnel) — dejar vacío para deshabilitar cada uno
# Para cada MCP: usa BEARER simple o Cloudflare Access Service Token (no ambos)

# StoneX MCP (cuenta + Market Intelligence)
STONEX_MCP_URL=https://stonex-mcp.aroco.tld/mcp
STONEX_MCP_TOKEN=tu-bearer-token
STONEX_MCP_CF_CLIENT_ID=
STONEX_MCP_CF_CLIENT_SECRET=

# Barchart MCP (cadena de opciones)
BARCHART_MCP_URL=https://barchart-mcp.aroco.tld/mcp
BARCHART_MCP_TOKEN=
BARCHART_MCP_CF_CLIENT_ID=
BARCHART_MCP_CF_CLIENT_SECRET=

# Inventory MCP (Google Sheet de inventario físico)
INVENTORY_MCP_URL=https://inventory-mcp.aroco.tld/mcp
INVENTORY_MCP_TOKEN=
INVENTORY_MCP_CF_CLIENT_ID=
INVENTORY_MCP_CF_CLIENT_SECRET=
